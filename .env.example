# Backend (set these in Render Dashboard → Environment)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net
DB_NAME=cricket_league
JWT_SECRET=your-long-random-secret-here
JWT_EXPIRATION=24h
PORT=10000

# Optional: override auto-detected Render URL for CORS (Render sets RENDER_EXTERNAL_URL automatically)
# FRONTEND_URL=https://your-app.onrender.com

# Google OAuth (backend)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: AI features
# GEMINI_API_KEY=your-gemini-api-key

# Frontend (local dev only — on Render, build.sh reads GOOGLE_CLIENT_ID automatically)
REACT_APP_BACKEND_URL=
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
